# === Google AI (Gemini) ===
GEMINI_API_KEY=your_gemini_api_key

# === Cloudinary ===
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional mockup base public IDs
CLOUDINARY_MOCKUP_TSHIRT_BLACK_PUBLIC_ID=ai-tee/mockups/tshirt-black
CLOUDINARY_MOCKUP_TSHIRT_WHITE_PUBLIC_ID=ai-tee/mockups/tshirt-white
CLOUDINARY_MOCKUP_SWEATSHIRT_BLACK_PUBLIC_ID=ai-tee/mockups/sweatshirt-black
CLOUDINARY_MOCKUP_SWEATSHIRT_WHITE_PUBLIC_ID=ai-tee/mockups/sweatshirt-white

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Krea.ai ===
KREA_API_TOKEN=your_krea_token
KREA_MODEL_ENDPOINT=google/nano-banana-2
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
IMAGE_STEPS=28

# === Obsidian (Codex Memory) ===
OBSIDIAN_VAULT_PATH=/Users/robertkispal/Obsidian/AI_memory

# === Admin Dashboard ===
ADMIN_PANEL_KEY=change_me_super_secret
